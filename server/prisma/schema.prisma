generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  STUDENT
  MENTOR
  ADMIN
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password_hash  String
  role           Role
  is_verified    Boolean  @default(false)
  created_at     DateTime @default(now())

  // Relations
  mentoredCourses Course[]
  enrollments     Enrollment[]
  progresses      Progress[]
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  mentor_id   String
  created_at  DateTime @default(now())

  // Relations
  mentor    User    @relation(fields: [mentor_id], references: [id])
  chapters  Chapter[]
  enrollments Enrollment[]
}

model Chapter {
  id              String   @id @default(cuid())
  course_id       String
  title           String
  description     String
  image_url       String?     // NEW: image support
  video_url       String?
  sequence_number Int

  course     Course   @relation(fields: [course_id], references: [id])
  progresses Progress[]

  @@unique([course_id, sequence_number])
  @@index([course_id])
}

model Enrollment {
  user_id     String
  course_id   String
  assigned_at DateTime @default(now())

  user   User   @relation(fields: [user_id], references: [id])
  course Course @relation(fields: [course_id], references: [id])

  @@id([user_id, course_id])       // composite primary key
}

model Progress {
  user_id      String
  chapter_id   String
  is_completed Boolean  @default(false)
  completed_at DateTime?

  user    User    @relation(fields: [user_id], references: [id])
  chapter Chapter @relation(fields: [chapter_id], references: [id])

  @@id([user_id, chapter_id])      // composite primary key
}
