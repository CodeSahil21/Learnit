{
  "version": 2,
  "installCommand": "cd client && npm install && cd ../server && npm install && npx prisma generate",
  "buildCommand": "cd client && ./node_modules/.bin/vite build",
  "outputDirectory": "client/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server/api/index.ts"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
